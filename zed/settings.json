{
  "base_keymap": "VSCode",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha (lavender)",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_weight": 500.0,
  "cursor_blink": false,
  "restore_on_startup": "launchpad",
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "terminal": {
    "font_size": 13,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
